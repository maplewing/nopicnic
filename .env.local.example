# Stripe
# Developers → API keys in Stripe dashboard
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook signing secret
# Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend
# resend.com → API Keys
# Domain nopicnicpress.com must be verified in Resend before sending live.
RESEND_API_KEY=re_...

# Loops
# loops.so → Settings → API Key
LOOPS_API_KEY=...

# Shippo (live shipping rates)
# goshippo.com → API → API Keys → use "Live" token for production
# Rate lookups are free; you only pay when purchasing labels through Shippo.
SHIPPO_API_KEY=shippo_live_...

# NPP origin ZIP code (used for Shippo rate calculation)
NPP_ORIGIN_ZIP=94710

# Site URL (no trailing slash)
NEXT_PUBLIC_URL=https://nopicnicpress.com

# Digital download token secret (also used to sign review approval tokens)
# Generate with: openssl rand -hex 32
DOWNLOAD_TOKEN_SECRET=your-long-random-secret-here

# GitHub — used to auto-commit approved reviews to data/products.js
# Create a fine-grained PAT at github.com/settings/personal-access-tokens/new
#   → Repository access: only this repo
#   → Permissions: Contents = Read and write
# GITHUB_REPO format: "username/repo-name"
GITHUB_TOKEN_NPP=github_pat_...
GITHUB_REPO=your-username/nopicnic
GITHUB_BRANCH=main

# Digital file URLs (set after uploading files to Vercel Blob or any host)
# Upload via: npx vercel blob upload <file>  — copies URL to clipboard
# Don't Call It That digital files
DCIT_EPUB_URL=
DCIT_PDF_URL=
DCIT_MOBI_URL=
# Run Studio Run digital files
RSR_EPUB_URL=
RSR_PDF_URL=
