# Stripe
# Developers → API keys in Stripe dashboard
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe webhook signing secret
# Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Resend
# resend.com → API Keys
# Domain nopicnicpress.com must be verified in Resend before sending live.
RESEND_API_KEY=re_...

# Loops
# loops.so → Settings → API Key
LOOPS_API_KEY=...

# Shippo (live shipping rates)
# goshippo.com → API → API Keys → use "Live" token for production
# Rate lookups are free; you only pay when purchasing labels through Shippo.
SHIPPO_API_KEY=shippo_live_...

# NPP origin ZIP code (used for Shippo rate calculation)
NPP_ORIGIN_ZIP=94710

# Site URL (no trailing slash)
NEXT_PUBLIC_URL=https://nopicnicpress.com
